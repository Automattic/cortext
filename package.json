{
	"name": "cortext",
	"version": "0.1.1",
	"description": "Knowledge base inside WordPress.",
	"engines": {
		"node": "^24.15",
		"pnpm": ">=11"
	},
	"private": true,
	"license": "GPL-2.0-or-later",
	"packageManager": "pnpm@11.0.8",
	"scripts": {
		"start": "wp-env start && pnpm run dev",
		"start:seed": "wp-env start && pnpm run env:seed && pnpm run dev",
		"dev": "wp-scripts start",
		"build": "wp-scripts build",
		"build:zip": "./scripts/build-zip.sh",
		"release:notes": "node scripts/release-notes.mjs",
		"format": "wp-scripts format",
		"format:check": "prettier --check '**/*.{js,jsx,json,ts,tsx,yml,yaml}' --config .prettierrc.js --ignore-path .prettierignore",
		"lint:js": "wp-scripts lint-js src",
		"lint:php": "composer run phpcs",
		"lint:style": "wp-scripts lint-style 'src/**/*.{css,pcss,scss}'",
		"env:start": "wp-env start",
		"env:start:seed": "wp-env start && pnpm run env:seed",
		"env:seed": "node scripts/wp-env-seed.mjs",
		"env:seed:full": "node scripts/wp-env-seed.mjs --full",
		"env:seed:reset": "node scripts/wp-env-seed.mjs --reset --force",
		"env:seed:reset:full": "node scripts/wp-env-seed.mjs --reset --force --full",
		"test:env:start": "wp-env --config .wp-env.test.json start",
		"test:env:start:seed": "wp-env --config .wp-env.test.json start && pnpm run test:env:seed",
		"test:env:seed": "node scripts/wp-env-seed.mjs --config .wp-env.test.json",
		"test:env:seed:full": "node scripts/wp-env-seed.mjs --config .wp-env.test.json --full",
		"test:env:seed:reset": "node scripts/wp-env-seed.mjs --config .wp-env.test.json --reset --force",
		"test:env:seed:reset:full": "node scripts/wp-env-seed.mjs --config .wp-env.test.json --reset --force --full",
		"test:unit": "wp-scripts test-unit-js --config jest.config.js && node --test tests/node/*.test.mjs",
		"test:unit:watch": "wp-scripts test-unit-js --config jest.config.js --watch",
		"test:e2e": "wp-scripts test-playwright --config playwright.config.js",
		"test:e2e:debug": "wp-scripts test-playwright --config playwright.config.js --ui"
	},
	"devDependencies": {
		"@playwright/test": "^1.48.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@wordpress/e2e-test-utils-playwright": "^1.44.0",
		"@wordpress/env": "^11.4.0",
		"@wordpress/prettier-config": "^4.46.0",
		"@wordpress/scripts": "^32.0.0",
		"prettier": "npm:wp-prettier@3.0.3",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"webpack-bundle-analyzer": "^5.3.0"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.1.0",
		"@dnd-kit/sortable": "^8.0.0",
		"@emoji-mart/data": "^1.2.1",
		"@emoji-mart/react": "^1.1.1",
		"@tanstack/react-router": "^1.168.23",
		"@wordpress/api-fetch": "^7.44.0",
		"@wordpress/base-styles": "^6.20.0",
		"@wordpress/block-editor": "^15.17.0",
		"@wordpress/block-library": "^9.44.0",
		"@wordpress/blocks": "^15.7.0",
		"@wordpress/commands": "^1.44.0",
		"@wordpress/components": "^32.6.0",
		"@wordpress/core-data": "^7.44.0",
		"@wordpress/data": "^10.44.0",
		"@wordpress/dataviews": "^6.0.0",
		"@wordpress/date": "^5.44.0",
		"@wordpress/editor": "^14.44.0",
		"@wordpress/element": "^6.44.0",
		"@wordpress/hooks": "^4.46.0",
		"@wordpress/i18n": "^6.17.0",
		"@wordpress/icons": "^12.2.0",
		"@wordpress/interface": "^9.0.0",
		"@wordpress/keyboard-shortcuts": "^5.44.0",
		"@wordpress/keycodes": "^4.45.0",
		"@wordpress/media-utils": "^5.45.0",
		"@wordpress/notices": "^5.44.0",
		"@wordpress/preferences": "^4.44.0",
		"@wordpress/private-apis": "^1.44.0",
		"@wordpress/route": "^0.10.0",
		"@wordpress/url": "^4.44.0",
		"cmdk": "^1.1.1",
		"emoji-mart": "^5.6.0"
	}
}
