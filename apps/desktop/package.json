{
	"name": "cortext-desktop",
	"version": "0.0.1",
	"description": "Cortext desktop app: Electron shell that runs Cortext on native PHP.",
	"private": true,
	"license": "GPL-2.0-or-later",
	"main": "main.js",
	"scripts": {
		"start": "electron .",
		"snapshot": "node scripts/build-snapshot.mjs",
		"runtime:php": "node scripts/install-runtime.mjs php",
		"runtime:franken": "node scripts/install-runtime.mjs franken",
		"runtime:caddy": "node scripts/install-runtime.mjs caddy",
		"bench:runtime": "node scripts/bench-runtime.mjs",
		"test": "npm run test:e2e",
		"test:e2e": "playwright test",
		"dist": "electron-builder"
	},
	"devDependencies": {
		"@playwright/test": "^1.48.0",
		"electron": "^33.2.0",
		"electron-builder": "^26.8.1"
	},
	"build": {
		"appId": "com.automattic.cortext",
		"productName": "Cortext",
		"directories": {
			"output": "dist"
		},
		"files": [
			"main.js",
			"loading.html",
			"error.html",
			"lib/**/*"
		],
		"extraResources": [
			"snapshot.zip",
			{
				"from": "runtime/bin/php",
				"to": "runtime/bin/php"
			},
			{
				"from": "runtime/mu-plugins/cortext-update-lock.php",
				"to": "runtime/mu-plugins/cortext-update-lock.php"
			}
		],
		"mac": {
			"target": [
				{
					"target": "dmg",
					"arch": "arm64"
				}
			],
			"identity": null,
			"category": "public.app-category.productivity"
		}
	}
}
